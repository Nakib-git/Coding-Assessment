# ═══════════════════════════════════════════════════════════════════════════════
# ERP Users — .gitignore
# Covers: .NET 8, Angular 18, PostgreSQL scripts, VS Code, Rider/JetBrains,
#         Windows, macOS, environment/secret files.
# ═══════════════════════════════════════════════════════════════════════════════


# ── .NET / MSBuild ───────────────────────────────────────────────────────────
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.vs/
.vs/
project.lock.json
project.fragment.lock.json

# NuGet
*.nupkg
*.snupkg
packages/
!**/packages/build/
nuget.config
*.nuget.props
*.nuget.targets

# EF Core migrations snapshots ARE committed — but ignore temp migration scripts
*.efbundle

# Publish artifacts
**/publish/
**/PublishProfiles/

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/

# Test coverage
*.coverage
*.coveragexml
coverage/
TestResults/
*.trx

# Crash dumps
*.dmp

# ── Secret & environment files ────────────────────────────────────────────────
# Never commit connection strings or API keys!
appsettings.Development.json
appsettings.Production.json
appsettings.Staging.json
# Keep the template appsettings.json (no real credentials)
!appsettings.json
.env
.env.*
!.env.example
secrets.json
*.pfx
*.p12

# ── Angular / Node.js ─────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.angular/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.yarn-integrity
frontend/.env
frontend/.env.*
!frontend/.env.example

# Angular cache
.angular/

# ── PostgreSQL / Database ─────────────────────────────────────────────────────
# Generated EF Core SQL scripts (use migrations instead)
# database/migrations/*.sql   ← we DO commit these

# ── IDE — Visual Studio Code ──────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/settings.json

# ── IDE — JetBrains (Rider, WebStorm) ────────────────────────────────────────
.idea/
*.iml
*.iws

# ── IDE — Visual Studio ───────────────────────────────────────────────────────
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb
[Ee]xpress/
DocProject/buildhelp/
DocProject/Help/*.HxT
DocProject/Help/*.HxC
DocProject/Help/*.hhc
DocProject/Help/*.hhk
DocProject/Help/*.hhp
DocProject/Help/Html2/
DocProject/Help/html/

# ── Windows ───────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── Miscellaneous ─────────────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
*.orig
*.log
